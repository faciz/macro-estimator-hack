# Azure OpenAI — chat/vision model used by /api/analyze (keyless via DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI — image generation used by /api/thumbnail (optional; falls back to no thumbnail)
# If omitted, AZURE_OPENAI_ENDPOINT is used as the image endpoint.
AZURE_OPENAI_IMAGE_ENDPOINT=https://YOUR-IMAGE-RESOURCE.cognitiveservices.azure.com
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1

# Azure Blob Storage for meal photos (optional; falls back to public/uploads on the local FS)
# The signed-in identity needs the "Storage Blob Data Contributor" role on the account.
AZURE_STORAGE_ACCOUNT=yourstorageacct
AZURE_STORAGE_CONTAINER=uploads

# API hardening (optional)
# Require clients to send an `x-api-key: <secret>` header on /api/* routes.
# API_SHARED_SECRET=change-me
# Per-IP request budget per minute (default: 20).
# API_RATE_LIMIT=20

# Auth (Microsoft Entra ID, optional)
# Set AUTH_REQUIRED=true to gate the app behind Microsoft sign-in. When false
# or unset, all routes are public.
# AUTH_REQUIRED=true
# 32+ byte random string used to sign session cookies. Generate with:
#   openssl rand -base64 32
# AUTH_SECRET=
# App registration details from your Entra tenant. Create a single-tenant Web
# app with redirect URI http://localhost:3000/api/auth/callback/microsoft-entra-id
# (and the equivalent for your deployed origin).
# AUTH_MICROSOFT_ENTRA_ID_ID=<Application (client) ID>
# AUTH_MICROSOFT_ENTRA_ID_SECRET=<Client secret value>
# AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<Tenant ID>/v2.0

# Google OAuth credentials (optional, enables "Sign in with Google").
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# of type "Web application" with authorized redirect URI
# http://localhost:3000/api/auth/callback/google (and your deployed origin).
# AUTH_GOOGLE_ID=<Client ID>
# AUTH_GOOGLE_SECRET=<Client secret>
