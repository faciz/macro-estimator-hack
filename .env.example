# Azure OpenAI — chat/vision model used by /api/analyze (keyless via DefaultAzureCredential)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure OpenAI — image generation used by /api/thumbnail (optional; falls back to no thumbnail)
# If omitted, AZURE_OPENAI_ENDPOINT is used as the image endpoint.
AZURE_OPENAI_IMAGE_ENDPOINT=https://YOUR-IMAGE-RESOURCE.cognitiveservices.azure.com
AZURE_OPENAI_IMAGE_DEPLOYMENT=gpt-image-1

# Azure Blob Storage for meal photos (optional; falls back to public/uploads on the local FS)
# The signed-in identity needs the "Storage Blob Data Contributor" role on the account.
AZURE_STORAGE_ACCOUNT=yourstorageacct
AZURE_STORAGE_CONTAINER=uploads

# API hardening (optional)
# Require clients to send an `x-api-key: <secret>` header on /api/* routes.
# API_SHARED_SECRET=change-me
# Per-IP request budget per minute (default: 20).
# API_RATE_LIMIT=20
